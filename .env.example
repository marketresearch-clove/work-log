PORT=3000

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Spreadsheet ID from the URL:  https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Shared Google Drive root folder (shared with service account)
DRIVE_FOLDER_ID=your_drive_folder_id_here

# ─── Google Service Account credentials ───────────────────────────────────────
# LOCAL DEV: path to the downloaded JSON key file (relative to project root)
CREDENTIALS_FILE=credentials.json

# PRODUCTION / SERVERLESS (Netlify · Vercel · Railway · Render):
# Paste the entire contents of your service account JSON on ONE line.
# Get it from: Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
# Example:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON=
